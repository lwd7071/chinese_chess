        # Build node info
        node_info = {'move': ..., 'g_cost': cost, 'piece_captured': piece_name, ...}
        
        # Add to frontier
        frontier_list.append(node_info)
        
        # Record step if recorder provided
        if recorder:
            sorted_frontier = sorted(frontier_list, key=lambda x: x['g_cost'])
            recorder.add_step(UCSStep(...))
        
